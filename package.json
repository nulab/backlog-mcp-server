{
  "name": "backlog-mcp-server",
  "version": "0.12.0",
  "type": "module",
  "bin": {
    "backlog-mcp-server": "./build/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.9",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nulab/backlog-mcp-server.git"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "tsx src/index.ts",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "build": "tsc && chmod 755 build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc --noEmit --project tsconfig.test.json",
    "typecheck:worker": "tsc --noEmit --project tsconfig.worker.json"
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "backlog-js": "^0.16.0",
    "cosmiconfig": "^9.0.1",
    "env-var": "^7.5.0",
    "graphql": "^16.14.1",
    "hono": "^4.12.25",
    "yargs": "^18.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^25.9.2",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@typescript-eslint/utils": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.3",
    "release-it": "^20.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.103.0"
  }
}