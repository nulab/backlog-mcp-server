BACKLOG_API_KEY=your-api-key
BACKLOG_DOMAIN=your-domain.backlog.com
# Optional multi-organization configuration.
# BACKLOG_DEFAULT_ORG=COMPANY_A
# BACKLOG_ORG_COMPANY_A_DOMAIN=company-a.backlog.com
# BACKLOG_ORG_COMPANY_A_API_KEY=your-company-a-api-key
# BACKLOG_ORG_COMPANY_B_DOMAIN=company-b.backlog.com
# BACKLOG_ORG_COMPANY_B_API_KEY=your-company-b-api-key

# OAuth 2.0 configuration (optional — enables remote MCP with per-user auth).
# When set, BACKLOG_API_KEY is not required; each user authenticates via Backlog OAuth.
# Register your app at https://backlog.com/developer/applications/ to get client credentials.
# BACKLOG_OAUTH_CLIENT_ID=your-oauth-client-id
# BACKLOG_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# MCP_SERVER_BASE_URL=https://your-mcp-server.example.com

# Multi-site OAuth configuration (optional — serve multiple Backlog organizations on one server).
# Each site is identified by BACKLOG_OAUTH_SITE_<NAME>_* env vars.
# When multi-site vars are present, single-site BACKLOG_OAUTH_* vars above are ignored.
# BACKLOG_OAUTH_SITE_MYCOMPANY_BASE_URL=https://mycompany-mcp.example.com
# BACKLOG_OAUTH_SITE_MYCOMPANY_DOMAIN=mycompany.backlog.com
# BACKLOG_OAUTH_SITE_MYCOMPANY_CLIENT_ID=your-mycompany-oauth-client-id
# BACKLOG_OAUTH_SITE_MYCOMPANY_CLIENT_SECRET=your-mycompany-oauth-client-secret
# BACKLOG_OAUTH_SITE_CUSTOMER_BASE_URL=https://customer-mcp.example.com
# BACKLOG_OAUTH_SITE_CUSTOMER_DOMAIN=customer.backlog.com
# BACKLOG_OAUTH_SITE_CUSTOMER_CLIENT_ID=your-customer-oauth-client-id
# BACKLOG_OAUTH_SITE_CUSTOMER_CLIENT_SECRET=your-customer-oauth-client-secret
