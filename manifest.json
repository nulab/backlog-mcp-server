{
  "manifest_version": "0.3",
  "name": "backlog-mcp-server",
  "display_name": "Backlog MCP Server",
  "version": "0.11.1",
  "description": "MCP server for Nulab Backlog project management service",
  "author": {
    "name": "nulab",
    "url": "https://nulab.com"
  },
  "server": {
    "type": "node",
    "entry_point": "build/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/build/index.js"
      ],
      "env": {
        "BACKLOG_API_KEY": "${user_config.backlog_api_key}",
        "BACKLOG_DOMAIN": "${user_config.backlog_domain}"
      }
    }
  },
  "tools_generated": true,
  "user_config": {
    "backlog_api_key": {
      "type": "string",
      "title": "Backlog API Key",
      "description": "API key for authenticating with Backlog",
      "required": true,
      "sensitive": true
    },
    "backlog_domain": {
      "type": "string",
      "title": "Backlog Domain",
      "description": "Your Backlog domain (e.g. your-space.backlog.com)",
      "required": true,
      "sensitive": false
    }
  },
  "keywords": [
    "backlog",
    "project-management",
    "nulab"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nulab/backlog-mcp-server.git"
  },
  "icon": "icon.png",
  "homepage": "https://github.com/nulab/backlog-mcp-server",
  "support": "https://github.com/nulab/backlog-mcp-server/issues"
}